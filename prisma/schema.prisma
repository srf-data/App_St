generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Fornecedores {
  Cod_Fornecedor Int       @id @default(autoincrement())
  Nome_Fornecedor String?
  Razao_Social    String?
  CNPJ            BigInt?
  Cidade          String?
  UF              String?   @db.VarChar(2)
  Contato         String?

  insumos         Insumo[]
}

model Produto {
  Cod_Produto           Int       @id @default(autoincrement())
  Nome_Produto          String?
  Quantidade_Cadastrada Int?
  Custo_Produto         Decimal?  @db.Decimal(10,2)
  Preco_Venda           Decimal?  @db.Decimal(10,2)
  Comissao_Porcentagem  Decimal?  @db.Decimal(10,2) @default(0)
  Dt_Cadastro           DateTime  @default(now())

  custos                CustoProduto[]
  entradas              EntradaProdutos[]
  saidas                SaidaProdutos[]
}

model Insumo {
  Cod_Insumo     Int       @id @default(autoincrement())
  Nome_Insumo    String?
  unidade        String?
  Custo_insumo      Decimal?  @db.Decimal(10,4)
  Estoque           Decimal?  @db.Decimal(10,3)
  Preco_Embalagem   Decimal?  @db.Decimal(10,2)
  Tamanho_Embalagem Decimal?  @db.Decimal(10,3)
  Cod_Fornecedor    Int?
  Dt_Cadastro       DateTime  @default(now())
  fornecedor     Fornecedores? @relation(fields: [Cod_Fornecedor], references: [Cod_Fornecedor])
  foto           String?   @db.Text

  custos         CustoProduto[]
  entradas       EntradaInsumos[]
  saidas         SaidaInsumos[]
}

model CustoProduto {
  Cod_Produto      Int
  Cod_Insumo       Int
  Nome_Insumo      String?
  Qtd_Utilizada    Decimal? @db.Decimal(10,3)
  Unidade          String?
  Custo_unitario   Decimal? @db.Decimal(10,2)
  Custo_Proporcional Decimal? @db.Decimal(10,2)

  produto Produto @relation(fields: [Cod_Produto], references: [Cod_Produto], onDelete: Cascade)
  insumo  Insumo  @relation(fields: [Cod_Insumo], references: [Cod_Insumo], onDelete: Cascade)

  @@id([Cod_Produto, Cod_Insumo])
}

model Usuarios {
  Cod_Usuario   Int       @id @default(autoincrement())
  Nome_Usuario  String?
  email         String?   @unique
  senha         String?
  foto          String?
  Dt_Cadastro   DateTime  @default(now())
  Ultimo_Acesso DateTime?
}

model EntradaProdutos {
  Cod_Entrada_Prod Int      @id @default(autoincrement())
  Cod_Produto      Int
  Nome_Produto     String?
  Quantidade       Decimal? @db.Decimal(10,3)
  Valor_Unitario   Decimal? @db.Decimal(10,2)
  Desconto         Decimal? @db.Decimal(10,2)
  Total            Decimal? @db.Decimal(10,2)
  DtEmissao        DateTime @default(now())
  DtEntrada        DateTime @default(now())
  DtCadastro       DateTime @default(now())

  produto Produto @relation(fields: [Cod_Produto], references: [Cod_Produto], onDelete: Cascade)
}

model EntradaInsumos {
  Cod_Entrada_Insumo Int      @id @default(autoincrement())
  Cod_Insumo         Int
  Nome_Insumo        String?
  Nome_Fornecedor    String?
  Quantidade         Decimal? @db.Decimal(10,3)
  Valor_Unitario     Decimal? @db.Decimal(10,2)
  Desconto           Decimal? @db.Decimal(10,2)
  Total              Decimal? @db.Decimal(10,2)
  DtEmissao          DateTime @default(now())
  DtEntrada          DateTime @default(now())
  DtCadastro         DateTime @default(now())

  insumo Insumo @relation(fields: [Cod_Insumo], references: [Cod_Insumo], onDelete: Cascade)
}

model SaidaProdutos {
  Cod_Saida_Prod Int      @id @default(autoincrement())
  Cod_Produto    Int
  Nome_Cliente   String?
  Nome_Produto   String?
  Quantidade     Decimal? @db.Decimal(10,3)
  Valor_Unitario Decimal? @db.Decimal(10,2)
  Desconto       Decimal? @db.Decimal(10,2) @default(0)
  Total          Decimal? @db.Decimal(10,2)
  DtSaida        DateTime @default(now())
  Status         String?

  produto Produto @relation(fields: [Cod_Produto], references: [Cod_Produto], onDelete: Cascade)
}

model SaidaInsumos {
  Cod_Saida_Insumo Int      @id @default(autoincrement())
  Cod_Insumo       Int
  Nome_Insumo      String?
  Quantidade       Decimal? @db.Decimal(10,3)
  Status           String?
  DtSaida          DateTime @default(now())

  insumo Insumo @relation(fields: [Cod_Insumo], references: [Cod_Insumo], onDelete: Cascade)
}
